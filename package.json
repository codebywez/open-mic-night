    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "nanoid": "^5.1.16",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
