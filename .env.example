# --- Open Mic Night environment ---
# Copy to .env.local and fill in from your Supabase project settings (Project Settings > API).

# Public Supabase project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key. Safe to expose to the browser (protected by Row Level Security).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. SERVER ONLY. Never expose to the browser. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL used to build shareable links + QR codes (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret required to call POST /api/cleanup (set to any long random string).
CLEANUP_SECRET=
